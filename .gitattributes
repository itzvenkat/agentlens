# Normalize line endings
* text=auto

# Source
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.html text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerignore text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
