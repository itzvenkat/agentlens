# AgentLens — Environment Configuration
# Copy this file to .env.development and fill in your values:
#   cp .env.example .env.development

NODE_ENV=development
APP_PORT=3000
APP_NAME=agentlens
APP_VERSION=0.1.0
APP_LOG_LEVEL=debug
APP_CORS_ORIGINS=http://localhost:3001

# Database (uses Docker service name as host)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=agentlens
DB_PASSWORD=your_password_here
DB_DATABASE=agentlens_dev
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth
AUTH_MASTER_KEY=your_master_key_here
AUTH_API_KEY_PREFIX=al_

# Processor
PROCESSOR_LOOP_THRESHOLD=3
PROCESSOR_AGGREGATION_INTERVAL=3600000
PROCESSOR_BATCH_FLUSH_INTERVAL=5000
