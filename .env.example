# AgentLens — Environment Configuration
# Copy this file to .env.development and fill in your values:
#   cp .env.example .env.development

NODE_ENV=development

# ── API Server ───────────────────────────────────────
APP_PORT=9471
APP_NAME=agentlens
APP_VERSION=0.1.0
APP_LOG_LEVEL=debug
APP_CORS_ORIGINS=http://localhost:9472

# ── Database ─────────────────────────────────────────
# Uses Docker service name as host in docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=agentlens
DB_PASSWORD=your_password_here
DB_DATABASE=agentlens_dev
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL=false

# ── Redis ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Auth ─────────────────────────────────────────────
# Master key for creating projects (first-time setup)
MASTER_API_KEY=your_master_key_here

# ── Processor ────────────────────────────────────────
LOOP_DETECTION_THRESHOLD=3

# ── LLM Proxy ────────────────────────────────────────
# API key for a project in AgentLens (create one first via the API)
AGENTLENS_API_KEY=
# Port for the proxy server
PROXY_PORT=9473
# Default upstream LLM provider (change to proxy other APIs)
UPSTREAM_BASE_URL=https://api.openai.com

# ── Dashboard ────────────────────────────────────────
DASHBOARD_PORT=9472
