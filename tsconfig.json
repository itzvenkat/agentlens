{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@agentlens/common": [
        "libs/common/src"
      ],
      "@agentlens/common/*": [
        "libs/common/src/*"
      ],
      "@agentlens/sdk": [
        "libs/sdk/src"
      ],
      "@agentlens/sdk/*": [
        "libs/sdk/src/*"
      ]
    }
  }
}